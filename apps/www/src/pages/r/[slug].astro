---
import Base from "@layouts/Base.astro";
import CodeTabs from "@components/CodeTabs.astro";
import ActionMenu from "@components/ActionMenu.astro";
import RemotionPreview from "@components/RemotionPreview";
import ExpoSnackEmbed from "@components/ExpoSnackEmbed.astro";
import CodePenExamples from "@components/CodePenExamples.astro";
import TechIcon from "@components/TechIcon.astro";
import { existsSync } from "node:fs";
import path from "node:path";
import { getCollection, render } from "astro:content";
import {
  getAlternateLinks,
  getLocaleFromUrl,
  getLocalePrefix,
  getLocalizedPath,
  useTranslations,
} from "@i18n/index";
import { BRAND_ALIASES, BRAND_NAME, mergeKeywords } from "@lib/seo";
import { SITE_URLS } from "@lib/urls";
import { findResourcePreview, normalizePreviewPath } from "@lib/resource-preview";

export async function getStaticPaths() {
  const resources = await getCollection("resources");
  return resources.map((resource) => ({
    params: { slug: resource.data.slug },
    props: { resource },
  }));
}

const { resource } = Astro.props;
const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);

const prefix = getLocalePrefix(locale);
const {
  slug,
  title,
  description,
  category,
  type,
  tags,
  tech,
  difficulty,
  targets,
  preview,
  labRoute,
  license,
  author,
  codepenExamples,
  createdAt,
  updatedAt,
} = resource.data;
const authorName = author?.name;

const { Content } = await render(resource);

const difficultyClass = { easy: "badge-easy", med: "badge-med", hard: "badge-hard" }[difficulty];
const difficultyKey = `resource.difficulty.${difficulty}` as
  | "resource.difficulty.easy"
  | "resource.difficulty.med"
  | "resource.difficulty.hard";
const difficultyLabel = t(difficultyKey);
const categoryKey = `category.${category}` as
  | "category.web-animations"
  | "category.web-pages"
  | "category.ui-components"
  | "category.patterns"
  | "category.components"
  | "category.pages"
  | "category.prompts"
  | "category.skills"
  | "category.mcp-servers"
  | "category.architectures"
  | "category.boilerplates"
  | "category.remotion"
  | "category.database-schemas"
  | "category.ultra-high-definition-pages"
  | "category.music";
const categoryLabel = t(categoryKey);

const CONTENT_DIR = path.resolve(process.cwd(), "../../packages/content");
const snippetsDir = path.join(CONTENT_DIR, `resources/${slug}/snippets`);
const hasJS = existsSync(path.join(snippetsDir, "script.js"));
const hasTS =
  existsSync(path.join(snippetsDir, "react.tsx")) ||
  existsSync(path.join(snippetsDir, "next.tsx")) ||
  existsSync(path.join(snippetsDir, "typescript.ts")) ||
  existsSync(path.join(snippetsDir, "typescript.tsx"));
const hasReactNative =
  existsSync(path.join(snippetsDir, "react-native.tsx")) ||
  existsSync(path.join(snippetsDir, "expo.tsx"));

const languageBadges = [...(hasTS ? ["TS"] : []), ...(hasJS ? ["JS"] : [])];

const TARGET_LABELS: Record<string, string> = {
  html: "HTML",
  react: "React",
  "react-native": "React Native",
  expo: "Expo",
  next: "Next.js",
  vue: "Vue",
  svelte: "Svelte",
  astro: "Astro",
  markdown: "Markdown",
  yaml: "YAML",
  json: "JSON",
  python: "Python",
  sql: "SQL",
  mermaid: "Mermaid",
  dbml: "DBML",
};

const targetLabels = targets.map((target) => TARGET_LABELS[target] ?? target);
const allBadges = [...languageBadges, ...targetLabels];
const frontmatterPreview = normalizePreviewPath(preview);
const detectedPreview = findResourcePreview(slug)?.publicPath;
const imagePath = frontmatterPreview ?? detectedPreview ?? `/og/${slug}.svg`;
const ogImageUrl = new URL(imagePath, "https://stealthis.dev").toString();
const baseResourcePath = `/r/${slug}`;
const canonicalPath = getLocalizedPath(baseResourcePath, locale);
const resourceUrl = `https://stealthis.dev${canonicalPath}`;
const alternateLinks = getAlternateLinks(baseResourcePath);
const resourceKeywords = mergeKeywords(BRAND_ALIASES, [
  BRAND_NAME,
  title,
  slug,
  slug.replaceAll("-", " "),
  `${title} example`,
  `${title} code snippet`,
  category,
  type,
  difficulty,
], tags, tech, targets);
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "TechArticle",
    headline: title,
    name: title,
    description,
    inLanguage: locale,
    url: resourceUrl,
    image: ogImageUrl,
    datePublished: new Date(createdAt).toISOString(),
    dateModified: new Date(updatedAt).toISOString(),
    license,
    keywords: resourceKeywords,
    about: { "@type": "Thing", name: category },
    author: {
      "@type": "Organization",
      name: BRAND_NAME,
      alternateName: BRAND_ALIASES,
      url: "https://stealthis.dev/",
    },
    publisher: {
      "@type": "Organization",
      name: BRAND_NAME,
      alternateName: BRAND_ALIASES,
      url: "https://stealthis.dev/",
    },
    isPartOf: {
      "@type": "WebSite",
      name: BRAND_NAME,
      alternateName: BRAND_ALIASES,
      url: "https://stealthis.dev/",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: t("resource.breadcrumb.home"),
        item: `https://stealthis.dev${prefix || "/"}`,
      },
      {
        "@type": "ListItem",
        position: 2,
        name: t("resource.breadcrumb.library"),
        item: `https://stealthis.dev${prefix}/library/`,
      },
      {
        "@type": "ListItem",
        position: 3,
        name: title,
        item: resourceUrl,
      },
    ],
  },
];
---

<Base
  title={title}
  description={description}
  image={imagePath}
  imageAlt={`${title} preview card`}
  canonicalPath={canonicalPath}
  keywords={resourceKeywords}
  alternateLinks={alternateLinks}
  structuredData={structuredData}
>
  <article class="container-md py-12" data-pagefind-body>
    <!-- Breadcrumb -->
    <nav class="text-sm text-slate-500 mb-8 flex items-center gap-2" aria-label="Breadcrumb">
      <a href={`${prefix || "/"}`} class="hover:text-slate-300 transition-colors">{t("resource.breadcrumb.home")}</a>
      <span>/</span>
      <a href={`${prefix}/library`} class="hover:text-slate-300 transition-colors">{t("resource.breadcrumb.library")}</a>
      <span>/</span>
      <span class="text-slate-300">{title}</span>
    </nav>

    <!-- Header -->
    <header class="mb-10">
      <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
        <div class="w-full min-w-0 md:flex-1">
          <div class="flex flex-wrap items-center gap-2 mb-3">
            <a href={`${prefix}/library?category=${category}`} class="chip hover:text-slate-200">
              {categoryLabel}
            </a>
            <span class={`badge ${difficultyClass}`}>{difficultyLabel}</span>
          </div>

          <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-white mb-3">
            {title}
          </h1>
          <p class="text-lg text-slate-400 leading-relaxed max-w-2xl">{description}</p>
        </div>

        <!-- Actions -->
        <div class="flex w-full flex-wrap items-center gap-2 md:w-auto md:flex-nowrap md:justify-end md:self-start">
          <button
            type="button"
            class="inline-flex items-center justify-center w-10 h-10 rounded-xl border border-white/10 text-slate-400 hover:text-slate-200 hover:bg-white/6 transition-colors resource-favorite-btn"
            data-slug={slug}
            data-label-save={t("resource.favorite")}
            data-label-saved={t("resource.unfavorite")}
            title={t("resource.favorite")}
            aria-label={t("resource.favorite")}
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
          </button>
          {category === "remotion" && (
            <a
              href={SITE_URLS.remotion}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-cyan-500/15 border border-cyan-400/30 text-sm font-medium text-cyan-300 hover:bg-cyan-500/25 hover:text-cyan-100 transition-colors"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
              </svg>
              {t("resource.openRemotion")}
            </a>
          )}
          {labRoute && (
            <a
              href={`${SITE_URLS.lab}${labRoute}`}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-cyan-500/15 border border-cyan-400/30 text-sm font-medium text-cyan-300 hover:bg-cyan-500/25 hover:text-cyan-100 transition-colors"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
              </svg>
              {t("resource.openLab")}
            </a>
          )}
          <ActionMenu resource={resource} locale={locale} resourceUrl={resourceUrl} />
        </div>
      </div>

      <!-- Tech tags -->
      {tech.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-5">
          {tech.map((item) => (
            <span class="chip inline-flex items-center gap-1.5">
              <TechIcon name={item} />
              {item}
            </span>
          ))}
        </div>
      )}

      <!-- Targets -->
      {targets.length > 0 && (
        <div class="flex flex-wrap items-center gap-2 mt-3">
          <span class="text-xs text-slate-600">{t("resource.targets")}:</span>
          {allBadges.map((label) => (
            <span class="text-xs font-mono px-2 py-0.5 rounded-md bg-white/4 border border-white/8 text-slate-400">
              {label}
            </span>
          ))}
        </div>
      )}
    </header>

    {category === "remotion" && (
      <section class="mb-12">
        <h2 class="text-sm font-semibold text-slate-500 uppercase tracking-wider mb-4">{t("resource.section.preview")}</h2>
        <div class="rounded-2xl border border-white/8 bg-surface-900/60 p-4">
          <RemotionPreview client:only="react" slug={slug} />
        </div>
      </section>
    )}

    {hasReactNative && (
      <section class="mb-12">
        <h2 class="text-sm font-semibold text-slate-500 uppercase tracking-wider mb-4">Expo Snack</h2>
        <ExpoSnackEmbed slug={slug} title={title} tech={tech} />
      </section>
    )}

    <!-- Code tabs -->
    <section class="mb-12">
      <h2 class="text-sm font-semibold text-slate-500 uppercase tracking-wider mb-4">{t("resource.section.code")}</h2>
      <CodeTabs slug={slug} targets={targets} />
    </section>

    <!-- CodePen examples -->
    {codepenExamples && codepenExamples.length > 0 && (
      <CodePenExamples
        examples={codepenExamples}
        sectionTitle={t("resource.codepenExamples")}
        previewLabel={t("resource.codepenLivePreview")}
        resource={resource}
        locale={locale}
      />
    )}

    <!-- Prose documentation -->
    <section class="mb-12">
      <div class="prose prose-invert prose-slate max-w-none
        prose-headings:font-bold prose-headings:tracking-tight
        prose-h2:text-2xl prose-h3:text-lg
        prose-p:text-slate-400 prose-p:leading-relaxed
        prose-a:text-brand-400 prose-a:no-underline hover:prose-a:text-brand-300
        prose-code:text-accent-300 prose-code:bg-white/6 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-sm prose-code:font-normal
        prose-pre:bg-surface-900 prose-pre:border prose-pre:border-white/8
        prose-li:text-slate-400
        prose-strong:text-slate-200">
        <Content />
      </div>
    </section>

    <!-- Metadata footer -->
    <footer class="border-t border-white/8 pt-8 flex flex-wrap items-center justify-between gap-4 text-sm text-slate-500">
      <div class="flex items-center gap-4 flex-wrap">
        <span>{t("resource.meta.license")}: <span class="text-slate-300">{license}</span></span>
        <span>{t("resource.meta.added")}: <span class="text-slate-300">{new Date(createdAt).toLocaleDateString()}</span></span>
        {author && authorName && (
          <span class="flex items-center gap-2">
            <span>{t("resource.author")}:</span>
            <a
              href={`${prefix}/library?author=${encodeURIComponent(authorName)}`}
              target="_blank"
              rel="noopener"
              class="text-brand-400 hover:text-brand-300 transition-colors"
            >
              {authorName}
            </a>
            <a
              href={author.src}
              target="_blank"
              rel="noopener"
              class="text-slate-500 hover:text-slate-300 transition-colors"
              title="GitHub repo"
              aria-label="GitHub repo"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.604-3.369-1.341-3.369-1.341-.454-1.154-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.741 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
              </svg>
            </a>
          </span>
        )}
      </div>
      <div class="flex flex-wrap gap-2">
        {tags.map((tag) => (
          <span class="chip text-xs">{tag}</span>
        ))}
      </div>
    </footer>
  </article>
</Base>

<script>
  import { isFavorite, toggleFavorite } from "@lib/favorites";

  function updateFavoriteButton(button: HTMLButtonElement, favorite: boolean) {
    const saveLabel = button.dataset.labelSave ?? "Save";
    const savedLabel = button.dataset.labelSaved ?? "Saved";
    const label = favorite ? savedLabel : saveLabel;

    button.classList.toggle("is-favorite", favorite);
    button.setAttribute("title", label);
    button.setAttribute("aria-label", label);
  }

  function initResourceFavoriteButtons() {
    const buttons = document.querySelectorAll<HTMLButtonElement>(".resource-favorite-btn");

    for (const button of buttons) {
      const slug = button.dataset.slug;
      if (!slug) continue;

      updateFavoriteButton(button, isFavorite(slug));

      if (button.dataset.favoriteInit === "true") continue;
      button.dataset.favoriteInit = "true";

      button.addEventListener("click", () => {
        const nextFavorite = toggleFavorite(slug);
        updateFavoriteButton(button, nextFavorite);
      });

      window.addEventListener("stealthis:favorites-changed", (event) => {
        if (!(event instanceof CustomEvent)) return;
        const detail = event.detail as { slug?: string } | undefined;
        if (detail?.slug && detail.slug !== slug) return;
        updateFavoriteButton(button, isFavorite(slug));
      });
    }
  }

  document.addEventListener("DOMContentLoaded", initResourceFavoriteButtons);
</script>

<style is:global>
  .resource-favorite-btn.is-favorite {
    @apply text-rose-400 border-rose-400/40 bg-rose-500/10;
  }

  .resource-favorite-btn.is-favorite svg {
    fill: currentColor;
  }

  /* Tailwind Typography plugin not included, manual prose styles */
  .prose h2 { @apply text-2xl font-bold text-white mt-10 mb-4; }
  .prose h3 { @apply text-lg font-semibold text-slate-200 mt-8 mb-3; }
  .prose p  { @apply text-slate-400 leading-relaxed mb-4; }
  .prose ul { @apply list-disc list-inside text-slate-400 mb-4 space-y-1; }
  .prose ol { @apply list-decimal list-inside text-slate-400 mb-4 space-y-1; }
  .prose li { @apply text-slate-400; }
  .prose strong { @apply font-semibold text-slate-200; }
  .prose code:not(pre code) {
    @apply font-mono text-accent-300 bg-white/6 px-1.5 py-0.5 rounded text-sm;
  }
  .prose a { @apply text-brand-400 hover:text-brand-300; }
  .prose table { @apply w-full text-sm border-collapse mb-4; }
  .prose th { @apply text-left font-semibold text-slate-300 border-b border-white/10 pb-2 pr-4; }
  .prose td { @apply text-slate-400 border-b border-white/6 py-2 pr-4; }
</style>
