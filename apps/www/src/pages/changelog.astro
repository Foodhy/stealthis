---
import Base from "@layouts/Base.astro";
import { getAlternateLinks, getLocaleFromUrl, useTranslations } from "@i18n/index";

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const alternateLinks = getAlternateLinks("/changelog");

// Changelog entries: add new releases at the top. Use en/es arrays for bilingual bullets.
const releases: Array<{
  date: string;
  version?: string;
  en: string[];
  es: string[];
}> = [
  {
    date: "2026-03-15",
    version: "0.4.0",
    en: [
      "DbViz added to the main navigation — visual database schema explorer that turns SQL into live ER diagrams. First-time visitors see an animated intro modal explaining how it works.",
      "Design Styles category is now fully searchable and browsable in the Library grid. All 24 style showcases (Brutalism, Glassmorphism, Neumorphism, Vaporwave, NES Retro, etc.) were previously missing from the main results.",
      "Phase 22 — Design Style Collections: 24 self-contained style showcases covering Classic, Dark & Atmospheric, Retro, and Modern & Trendy aesthetics.",
      "i18n expanded to 15 languages with improved locale selector UX and language persistence across navigation.",
      "Phases 12–16 content complete: Full Page Templates, Email & Notifications, Integration Patterns, Widgets & Media, and Developer Tools & AI UI (130+ new resources).",
      "MCP server documented with full use-case reference and updated catalog.",
    ],
    es: [
      "DbViz añadido a la navegación principal — explorador visual de esquemas de base de datos que convierte SQL en diagramas ER en vivo. Los visitantes por primera vez ven un modal animado explicando cómo funciona.",
      "La categoría Design Styles ahora es completamente buscable y navegable en la cuadrícula de la Biblioteca. Los 24 showcases de estilos (Brutalism, Glassmorphism, Neumorphism, Vaporwave, NES Retro, etc.) no aparecían en los resultados principales.",
      "Fase 22 — Design Style Collections: 24 showcases de estilos autocontenidos que cubren estéticas Clásicas, Oscuras y Atmosféricas, Retro y Modernas.",
      "i18n ampliado a 15 idiomas con UX mejorada en el selector de idioma y persistencia del idioma entre navegación.",
      "Fases 12–16 completas: Plantillas de páginas completas, Email y Notificaciones, Patrones de integración, Widgets y Media, y Herramientas para desarrolladores y UI de IA (130+ recursos nuevos).",
      "Servidor MCP documentado con referencia completa de casos de uso y catálogo actualizado.",
    ],
  },
  {
    date: "2026-03-01",
    version: "0.3.0",
    en: [
      "Builder app: new scaffold/plan APIs, React Flow project graph, export to ZIP, and file system access.",
      "Showcase page: live demo grid with embedded iframe previews for all resources with lab routes.",
      "Dynamic OG images for home, docs, lab, library, changelog, and showcase pages.",
      "Phase 7 UI Components Deep Cut: 30+ new components (alert-dialog, anchor-nav, autocomplete, back-to-top, bottom-nav, chat-bubble, diff-slider, fab-speed-dial, image-lightbox, mega-menu, mockup-browser, mockup-phone, qr-code, and more).",
      "Resource preview endpoint for programmatic preview generation.",
      "LLM index and AI index endpoints for discoverability.",
    ],
    es: [
      "App Builder: nuevas APIs de scaffold/plan, grafo de proyecto con React Flow, exportación a ZIP y acceso al sistema de archivos.",
      "Página Showcase: grid de demos en vivo con previews embebidos para todos los recursos con rutas lab.",
      "Imágenes OG dinámicas para home, docs, lab, library, changelog y showcase.",
      "Phase 7 UI Components Deep Cut: 30+ componentes nuevos (alert-dialog, anchor-nav, autocomplete, back-to-top, bottom-nav, chat-bubble, diff-slider, fab-speed-dial, image-lightbox, mega-menu, mockup-browser, mockup-phone, qr-code, y más).",
      "Endpoint de preview de recursos para generación programática.",
      "Endpoints de índice LLM y AI para descubribilidad.",
    ],
  },
  {
    date: "2026-03-01",
    version: "0.2.0",
    en: [
      "Redesigned the Roadmap section with a flowing SVG path-drawing scroll animation and a cleaner, open layout.",
      "Enhanced the Examples marquee feature to include three distinct tiers (Easy, Medium, Hard) matching their responsive scroll speeds.",
      "Elevated the 'Steal This philosophy' section with a bold, centered scramble effect and refined typography.",
      "Removed card-like boxing from the Project Language section to provide a more spacious and modern aesthetic.",
      "General UI/UX improvements to the homepage animations and spacing.",
    ],
    es: [
      "Rediseñada la sección Roadmap con una animación fluida de trazado SVG al hacer scroll y un diseño más limpio y abierto.",
      "Mejorada la marquesina de Ejemplos para incluir tres niveles distintos (Fácil, Medio, Difícil) que coinciden con su velocidad adaptativa.",
      "Elevada la sección 'Filosofía Steal This' con un efecto scramble centrado y tipografía refinada.",
      "Eliminado el diseño tipo tarjeta de la sección 'Lenguaje del proyecto' para brindar una estética más espaciosa y moderna.",
      "Mejoras generales de UI/UX en las animaciones y espaciado de la página principal.",
    ],
  },
  {
    date: "2026-02-21",
    version: "0.1.0",
    en: [
      "New Changelog page on the site.",
      "Hero animations: count-up stats and smooth entrance for title, subtitle, and CTAs.",
      "Integration docs updated: MCP server URL is https://mcp.stealthis.dev/mcp.",
      "Music category added as Coming soon in Browse by Category.",
      "Hero subtitle rephrased to «Ready-to-use snippets and demos».",
    ],
    es: [
      "Nueva página Changelog en el sitio.",
      "Animaciones en el hero: números que suben y entrada suave del título, subtítulo y CTAs.",
      "Docs de integración actualizados: URL del servidor MCP es https://mcp.stealthis.dev/mcp.",
      "Categoría Music añadida como Próximamente en Explorar por categoría.",
      "Subtítulo del hero reescrito a «Snippets y demos listos para usar».",
    ],
  },
];
---

<Base
  title={t("changelog.title")}
  description={t("changelog.description")}
  image="/og/changelog.webp"
  canonicalPath="/changelog"
  alternateLinks={alternateLinks}
>
  <section class="container-xl py-16 pb-20">
    <header class="mb-12">
      <h1 class="text-3xl font-bold text-white tracking-tight">{t("changelog.title")}</h1>
      <p class="mt-3 text-slate-400 max-w-xl">{t("changelog.intro")}</p>
      <a
        href="https://github.com/Foodhy/stealthis/releases"
        target="_blank"
        rel="noopener"
        class="inline-block mt-4 text-sm text-brand-400 hover:text-brand-300 font-medium"
      >
        {t("changelog.seeGitHub")} →
      </a>
    </header>

    <div class="space-y-12">
      {releases.map((release) => {
        const items = locale === "es" ? release.es : release.en;
        const displayDate = new Date(release.date).toLocaleDateString(locale === "es" ? "es-ES" : "en-US", {
          year: "numeric",
          month: "long",
          day: "numeric",
        });
        return (
          <article class="border border-white/8 rounded-2xl bg-surface-900/30 p-6 sm:p-8">
            <div class="flex flex-wrap items-baseline gap-3 mb-4">
              <time datetime={release.date} class="text-sm text-slate-500">
                {displayDate}
              </time>
              {release.version && (
                <span class="text-sm font-medium text-brand-400">v{release.version}</span>
              )}
            </div>
            <ul class="list-disc list-inside space-y-2 text-slate-300">
              {items.map((item) => (
                <li class="pl-1">{item}</li>
              ))}
            </ul>
          </article>
        );
      })}
    </div>
  </section>
</Base>
