---
import Base from "@layouts/Base.astro";
import ResourceCard from "@components/ResourceCard.astro";
import FilterBar from "@components/FilterBar.astro";
import CollectionExplorer from "@components/CollectionExplorer.astro";
import { getCollection } from "astro:content";
import { getAlternateLinks, getLocaleFromUrl, getLocalePrefix, useTranslations } from "@i18n/index";
import { SHOW_SORT_BAR } from "@lib/constant";
import { getResourceFilterTechTokens } from "@lib/resource-tech";
import { BRAND_ALIASES, BRAND_NAME, mergeKeywords } from "@lib/seo";

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const prefix = getLocalePrefix(locale);

const allResources = (await getCollection("resources")).sort(
  (a, b) => new Date(b.data.createdAt).getTime() - new Date(a.data.createdAt).getTime()
);

const categories = [...new Set(allResources.map((r) => r.data.category))].sort();
const techSet = new Set<string>();
for (const resource of allResources) {
  for (const tech of getResourceFilterTechTokens(resource)) {
    techSet.add(tech);
  }
}

const PRIORITY_TECHS = ["js", "css", "html", "react"];
const techs = [
  ...PRIORITY_TECHS.filter((tech) => techSet.has(tech)),
  ...[...techSet].filter((tech) => !PRIORITY_TECHS.includes(tech)).sort(),
];
const authors = [
  ...new Set(allResources.flatMap((r) => (r.data.author ? [r.data.author.name] : []))),
].sort();

// Group resources by category
const byCategory = new Map<string, typeof allResources>();
for (const r of allResources) {
  const cat = r.data.category;
  if (!byCategory.has(cat)) byCategory.set(cat, []);
  byCategory.get(cat)!.push(r);
}

const CATEGORY_GROUPS = [
  {
    id: "visual",
    label: "Visual & Code",
    description: "Copy-paste UI, animations, and components",
    categories: [
      "web-animations",
      "web-pages",
      "pages",
      "ui-components",
      "patterns",
      "components",
      "remotion",
      "ultra-high-definition-pages",
    ],
  },
  {
    id: "ai",
    label: "AI & Dev",
    description: "Prompts, skills, architectures, and server configs",
    categories: ["prompts", "skills", "mcp-servers", "architectures", "boilerplates"],
  },
  {
    id: "data",
    label: "Data & SQL",
    description: "Relational schemas with SQL, ERD diagrams, seed data, and query examples",
    categories: ["database-schemas"],
  },
] as const;

type CategoryKey =
  | "category.web-animations"
  | "category.web-pages"
  | "category.ui-components"
  | "category.patterns"
  | "category.components"
  | "category.pages"
  | "category.prompts"
  | "category.skills"
  | "category.mcp-servers"
  | "category.architectures"
  | "category.boilerplates"
  | "category.remotion"
  | "category.database-schemas"
  | "category.ultra-high-definition-pages";

const libraryDescription =
  "Search open-source resources by category, tech, difficulty, author, and collections. Copy snippets, inspect SQL schemas, or open demos in Lab.";
const canonicalPath = `${prefix}/library/`;
const alternateLinks = getAlternateLinks("/library/");
const libraryKeywords = mergeKeywords(BRAND_ALIASES, [
  BRAND_NAME,
  "stealthis library",
  "steal this library",
  "resource library",
  "component library",
  "animation library",
  "frontend snippets",
  "open source components",
  "SQL schema examples",
]);
const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "StealThis.dev Library",
  url: `https://stealthis.dev${canonicalPath}`,
  inLanguage: locale,
  description: libraryDescription,
  keywords: libraryKeywords,
  numberOfItems: allResources.length,
  isPartOf: {
    "@type": "WebSite",
    name: BRAND_NAME,
    alternateName: BRAND_ALIASES,
    url: "https://stealthis.dev/",
  },
};
---

<Base
  title={t("library.title")}
  description={libraryDescription}
  image="/og/library.webp"
  canonicalPath={canonicalPath}
  keywords={libraryKeywords}
  alternateLinks={alternateLinks}
  structuredData={structuredData}
>
  <div class="container-xl py-12" data-pagefind-ignore>
    <!-- Header -->
    <div class="mb-10">
      <h1 class="text-4xl font-extrabold tracking-tight text-white mb-2">{t("library.title")}</h1>
      <p class="text-slate-400">{t("library.subtitle")} — {allResources.length} resources</p>
    </div>

    <CollectionExplorer locale={locale} resources={allResources} />

    <div class="flex flex-col lg:flex-row gap-8">
      <!-- Sidebar: filters -->
      <aside class="w-full lg:w-64 shrink-0">
        <FilterBar locale={locale} categories={categories} techs={techs} authors={authors} />

        <div class="mt-6 flex flex-col gap-2">
          <button
            id="export-favorites"
            class="w-full text-sm font-medium px-4 py-2.5 rounded-xl border border-white/10 text-slate-400 hover:text-slate-200 hover:bg-white/6 transition-colors text-left"
          >
            ↑ {t("favorites.export")}
          </button>
          <label class="w-full text-sm font-medium px-4 py-2.5 rounded-xl border border-white/10 text-slate-400 hover:text-slate-200 hover:bg-white/6 transition-colors cursor-pointer">
            ↓ {t("favorites.import")}
            <input type="file" accept=".json" class="hidden" id="import-favorites-input" />
          </label>
        </div>
      </aside>

      <!-- Resource grid -->
      <div class="flex-1 min-w-0" id="resource-grid">

        <!-- Sort bar -->
        {SHOW_SORT_BAR && (
        <div class="flex items-center gap-2 mb-6">
          <span class="text-xs text-slate-500 shrink-0">{t("library.sort.grouped").split(" ")[0]}:</span>
          <button id="sort-grouped" class="chip chip--active">{t("library.sort.grouped")}</button>
          <button id="sort-latest" class="chip">{t("library.sort.latest")}</button>
        </div>
        )}

        <!-- Flat grid — shown in "latest" mode -->
        <div id="flat-grid" class="hidden grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4 mb-12"></div>

        {CATEGORY_GROUPS.map((group) => {
          const hasAny = group.categories.some((c) => (byCategory.get(c)?.length ?? 0) > 0);
          if (!hasAny) return null;
          return (
            <div data-category-group={group.id} class="mb-12">
              <!-- Group header -->
              <div class="flex items-center gap-3 mb-6">
                <h2 class="text-base font-bold text-white whitespace-nowrap">{group.label}</h2>
                <span class="text-xs text-slate-600 whitespace-nowrap hidden sm:block">{group.description}</span>
                <div class="flex-1 border-t border-white/6"></div>
              </div>

              {group.categories.map((cat) => {
                const resources = byCategory.get(cat);
                if (!resources?.length) return null;
                const catKey = `category.${cat}` as CategoryKey;
                return (
                  <div data-category-section={cat} class="mb-8 last:mb-0">
                    <div class="flex items-center gap-2 mb-3">
                      <h3 class="text-sm font-semibold text-slate-400">{t(catKey)}</h3>
                      <span class="text-xs text-slate-600 tabular-nums">{resources.length}</span>
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4">
                      {resources.map((resource) => (
                        <ResourceCard resource={resource} locale={locale} />
                      ))}
                    </div>
                  </div>
                );
              })}
            </div>
          );
        })}

        <!-- Empty state -->
        <p class="hidden text-center text-slate-500 py-16" id="empty-state">
          {t("library.noResults")}
        </p>
      </div>
    </div>
  </div>
</Base>

<script>
  import { exportFavorites, importFavorites } from "@lib/favorites";

  // ── Sort: grouped vs latest ──────────────────────────────────────
  const flatGrid     = document.getElementById("flat-grid") as HTMLElement;
  const sortGrouped  = document.getElementById("sort-grouped") as HTMLButtonElement;
  const sortLatest   = document.getElementById("sort-latest") as HTMLButtonElement;

  // Store each card's original parent grid and use a persistent anchor comment
  type CardOrigin = { parent: Element; anchor: Comment };
  const origins = new Map<Element, CardOrigin>();
  document.querySelectorAll<HTMLElement>("article[data-slug]").forEach((card) => {
    const anchor = document.createComment("card-anchor");
    card.parentElement!.insertBefore(anchor, card);
    origins.set(card, { parent: card.parentElement!, anchor });
  });

  let sortMode: "grouped" | "latest" = "grouped";

  function activateLatest() {
    if (sortMode === "latest") return;
    sortMode = "latest";
    sortGrouped.classList.remove("chip--active");
    sortLatest.classList.add("chip--active");

    // Collect all cards, sort newest first
    const cards = [...origins.keys()] as HTMLElement[];
    cards.sort((a, b) => {
      const tA = new Date(a.dataset.createdAt ?? "").getTime();
      const tB = new Date(b.dataset.createdAt ?? "").getTime();
      return tB - tA;
    });

    flatGrid.innerHTML = "";
    for (const card of cards) flatGrid.appendChild(card);

    // Hide category groups, clear any inline display override, then show flat grid
    document.querySelectorAll<HTMLElement>("[data-category-group]").forEach((g) => (g.style.display = "none"));
    flatGrid.style.display = "";
    flatGrid.classList.remove("hidden");
  }

  function activateGrouped() {
    if (sortMode === "grouped") return;
    sortMode = "grouped";
    sortLatest.classList.remove("chip--active");
    sortGrouped.classList.add("chip--active");

    // Restore each card right after its persistent anchor comment
    for (const [card, { parent, anchor }] of origins.entries()) {
      parent.insertBefore(card, anchor.nextSibling);
    }

    flatGrid.classList.add("hidden");
    flatGrid.style.display = "";

    // Re-evaluate section visibility based on each card's current display state
    // (FilterBar already applied filters while cards were in flat-grid).
    document.querySelectorAll<HTMLElement>("[data-category-section]").forEach((section) => {
      const hasVisible = [...section.querySelectorAll<HTMLElement>("article[data-slug]")]
        .some((c) => c.style.display !== "none");
      section.style.display = hasVisible ? "" : "none";
    });

    // Re-evaluate group visibility based on whether any of its sections are visible.
    document.querySelectorAll<HTMLElement>("[data-category-group]").forEach((g) => {
      const hasVisible = [...g.querySelectorAll<HTMLElement>("[data-category-section]")]
        .some((s) => s.style.display !== "none");
      g.style.display = hasVisible ? "" : "none";
    });
  }

  sortLatest.addEventListener("click", activateLatest);
  sortGrouped.addEventListener("click", activateGrouped);

  document.getElementById("export-favorites")?.addEventListener("click", exportFavorites);

  const importInput = document.getElementById("import-favorites-input") as HTMLInputElement | null;
  importInput?.addEventListener("change", async () => {
    const file = importInput.files?.[0];
    if (!file) return;
    try {
      const count = await importFavorites(file);
      alert(`Imported ${count} favorites!`);
    } catch {
      alert("Invalid favorites file.");
    }
    importInput.value = "";
  });
</script>
