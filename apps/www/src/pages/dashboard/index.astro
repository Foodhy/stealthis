---
import Base from "@layouts/Base.astro";
import { DEFAULT_LOCALE, LOCALE_STORAGE_KEY, getLocaleFromUrl, isLocale, useTranslations } from "@i18n/index";

export const prerender = false;

let locale = getLocaleFromUrl(Astro.url);
if (locale === DEFAULT_LOCALE) {
  const cookieLocale = Astro.cookies.get(LOCALE_STORAGE_KEY)?.value;
  if (isLocale(cookieLocale)) locale = cookieLocale;
}
const t = useTranslations(locale);
const title = t("dashboard.title");
---

<Base title={title}>
  <main class="min-h-[60vh] container-xl py-10">
    <section class="max-w-2xl">
      <p class="text-xs uppercase tracking-[0.25em] text-slate-500 mb-2">{t("dashboard.account")}</p>
      <h1 class="text-3xl font-semibold text-white mb-3">{title}</h1>
      <p class="text-slate-400 mb-8">
        {t("dashboard.description")}
      </p>
    </section>
  </main>
</Base>

