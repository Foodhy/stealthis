---
import Base from "@layouts/Base.astro";
import ResourceCard from "@components/ResourceCard.astro";
import FilterBar from "@components/FilterBar.astro";
import CollectionExplorer from "@components/CollectionExplorer.astro";
import { getCollection } from "astro:content";
import { useTranslations } from "@i18n/index";

const locale = "es" as const;
const t = useTranslations(locale);
const allResources = (await getCollection("resources")).sort(
  (a, b) => new Date(b.data.createdAt).getTime() - new Date(a.data.createdAt).getTime()
);
const categories = [...new Set(allResources.map((r) => r.data.category))].sort();
const techs = [...new Set(allResources.flatMap((r) => r.data.tech))].sort();
const authors = [
  ...new Set(allResources.flatMap((r) => (r.data.author ? [r.data.author.name] : []))),
].sort();
const libraryDescription =
  "Busca más de 200 recursos web open source por categoría, tech, dificultad, autor y colecciones. Copia snippets o abre demos en Lab.";
const alternateLinks = [
  { hreflang: "en", href: "https://stealthis.dev/library/" },
  { hreflang: "es", href: "https://stealthis.dev/es/library/" },
  { hreflang: "x-default", href: "https://stealthis.dev/library/" },
];
const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "StealThis.dev Librería",
  url: "https://stealthis.dev/es/library/",
  inLanguage: "es",
  description: libraryDescription,
  numberOfItems: allResources.length,
};
---

<Base
  title="Librería"
  description={libraryDescription}
  image="/og/library.webp"
  canonicalPath="/es/library/"
  alternateLinks={alternateLinks}
  structuredData={structuredData}
>
  <div class="container-xl py-12">
    <div class="mb-10">
      <h1 class="text-4xl font-extrabold tracking-tight text-white mb-2">{t("library.title")}</h1>
      <p class="text-slate-400">{t("library.subtitle")} — {allResources.length} recursos</p>
    </div>

    <CollectionExplorer locale={locale} resources={allResources} />

    <div class="flex flex-col lg:flex-row gap-8">
      <aside class="w-full lg:w-64 shrink-0">
        <FilterBar locale={locale} categories={categories} techs={techs} authors={authors} />
      </aside>
      <div class="flex-1 min-w-0">
        <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4">
          {allResources.map((resource) => (
            <ResourceCard resource={resource} locale={locale} />
          ))}
        </div>
      </div>
    </div>
  </div>
</Base>
