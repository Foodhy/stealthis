---
import {
  DEFAULT_LOCALE,
  LOCALES,
  LOCALE_LABELS,
  LOCALE_STORAGE_KEY,
  getLocalePrefix,
  type Locale,
  useTranslations,
} from "@i18n/index";
import { SITE_URLS } from "@lib/urls";
import { SHOW_BUILD_BUTTON, SHOW_STYLEFORGE_STUDIO } from "@lib/constant";

const { locale } = Astro.props as { locale: Locale };
const t = useTranslations(locale);
const prefix = getLocalePrefix(locale);
const localeFlags: Record<Locale, string> = {
  en: "🇺🇸",
  es: "🇪🇸",
  fr: "🇫🇷",
  ja: "🇯🇵",
  ms: "🇲🇾",
  hi: "🇮🇳",
  ko: "🇰🇷",
  nl: "🇳🇱",
  de: "🇩🇪",
  "pt-br": "🇧🇷",
  "zh-hk": "🇭🇰",
  "zh-cn": "🇨🇳",
  it: "🇮🇹",
  pl: "🇵🇱",
};
const localeOptionLabels: Record<Locale, string> = {
  en: t("lang.option.en"),
  es: t("lang.option.es"),
  fr: t("lang.option.fr"),
  ja: t("lang.option.ja"),
  ms: t("lang.option.ms"),
  hi: t("lang.option.hi"),
  ko: t("lang.option.ko"),
  nl: t("lang.option.nl"),
  de: t("lang.option.de"),
  "pt-br": t("lang.option.pt-br"),
  "zh-hk": t("lang.option.zh-hk"),
  "zh-cn": t("lang.option.zh-cn"),
  it: t("lang.option.it"),
  pl: t("lang.option.pl"),
};
const localeOptionDisplay: Record<Locale, string> = Object.fromEntries(
  LOCALES.map((optionLocale) => {
    const nativeLabel = LOCALE_LABELS[optionLocale];
    const localizedLabel = localeOptionLabels[optionLocale];
    const combinedLabel =
      nativeLabel === localizedLabel ? nativeLabel : `${nativeLabel} · ${localizedLabel}`;
    return [optionLocale, combinedLabel];
  }),
) as Record<Locale, string>;
const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
const normalizePath = (path: string) => path.replace(/\/$/, "") || "/";
const isNavLinkActive = (href: string, external: boolean) => {
  if (external) return false;
  const normalizedHref = normalizePath(href);
  return currentPath === normalizedHref || currentPath.startsWith(`${normalizedHref}/`);
};

const navLinks = [
  { key: "library", href: `${prefix}/library`, label: t("nav.library"), external: false, badge: "" },
  { key: "showcase", href: `${prefix}/showcase`, label: t("nav.showcase"), external: false, badge: "New" },
  { key: "docs", href: SITE_URLS.docs, label: t("nav.docs"), external: true, badge: "" },
  { key: "lab", href: SITE_URLS.lab, label: t("nav.lab"), external: true, badge: "" },
  { key: "build", href: SITE_URLS.build, label: t("nav.build"), external: true, badge: "" },
  {
    key: "styleforge",
    href: SITE_URLS.styleforge,
    label: t("nav.styleforge"),
    external: true,
    badge: "",
  },
];

const visibleNavLinks = navLinks.filter(
  (link) =>
    (link.key !== "styleforge" || SHOW_STYLEFORGE_STUDIO) &&
    (link.key !== "build" || SHOW_BUILD_BUTTON),
);

const menuLabels: Record<Locale, { open: string; close: string; title: string }> = {
  en: { open: "Open menu", close: "Close menu", title: "Navigation" },
  es: { open: "Abrir menu", close: "Cerrar menu", title: "Navegacion" },
  fr: { open: "Ouvrir le menu", close: "Fermer le menu", title: "Navigation" },
  ja: { open: "メニューを開く", close: "メニューを閉じる", title: "ナビゲーション" },
  ms: { open: "Buka menu", close: "Tutup menu", title: "Navigasi" },
  hi: { open: "मेनू खोलें", close: "मेनू बंद करें", title: "नेविगेशन" },
  ko: { open: "메뉴 열기", close: "메뉴 닫기", title: "내비게이션" },
  nl: { open: "Menu openen", close: "Menu sluiten", title: "Navigatie" },
  de: { open: "Menü öffnen", close: "Menü schließen", title: "Navigation" },
  "pt-br": { open: "Abrir menu", close: "Fechar menu", title: "Navegação" },
  "zh-hk": { open: "開啟選單", close: "關閉選單", title: "導覽" },
  "zh-cn": { open: "打开菜单", close: "关闭菜单", title: "导航" },
  it: { open: "Apri menu", close: "Chiudi menu", title: "Navigazione" },
  pl: { open: "Otwórz menu", close: "Zamknij menu", title: "Nawigacja" },
};

const menuOpenLabel = menuLabels[locale].open;
const menuCloseLabel = menuLabels[locale].close;
const menuTitle = menuLabels[locale].title;
---

<header class="sticky top-0 z-50 border-b border-white/6 bg-surface-950/80 backdrop-blur-xl">
  <div class="container-xl flex items-center justify-between h-14">
    <a href={`${prefix}/`} class="flex items-center gap-2 font-bold text-sm">
      <span class="text-brand-400 text-lg">✦</span>
      <span class="text-white">StealThis</span>
      <span class="text-slate-500">.dev</span>
    </a>

    <nav class="hidden sm:flex items-center gap-1" aria-label="Main navigation">
      {visibleNavLinks.map((link) => (
        <a
          href={link.href}
          class={`nav-link ${isNavLinkActive(link.href, link.external) ? "is-active" : ""}`}
          target={link.external ? "_blank" : undefined}
          rel={link.external ? "noopener" : undefined}
        >
          {link.label}
          {link.badge && <span class="nav-badge">{link.badge}</span>}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <label class="sr-only" for="desktop-language-select">{t("lang.label")}</label>
      <select
        id="desktop-language-select"
        class="hidden sm:inline-block lang-select"
        aria-label={t("lang.label")}
        data-language-select
        data-current-locale={locale}
      >
        {LOCALES.map((optionLocale) => (
          <option value={optionLocale}>{`${localeFlags[optionLocale]} ${localeOptionDisplay[optionLocale]}`}</option>
        ))}
      </select>

      <a
        href="https://github.com/Foodhy/stealthis"
        target="_blank"
        rel="noopener noreferrer"
        class="hidden sm:flex items-center gap-1.5 text-xs font-medium px-3 py-1.5 rounded-lg bg-white/6 border border-white/10 text-slate-300 hover:bg-white/10 hover:text-white transition-colors"
        aria-label="GitHub"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"></path>
        </svg>
        GitHub
      </a>

      <button
        type="button"
        class="mobile-menu-trigger inline-flex items-center justify-center w-9 h-9 rounded-lg border border-white/10 bg-white/5 text-slate-300 hover:text-white hover:bg-white/10 transition-colors"
        aria-label={menuOpenLabel}
        aria-controls="mobile-nav-drawer"
        aria-expanded="false"
        data-mobile-menu-button
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="4" y1="7" x2="20" y2="7"></line>
          <line x1="4" y1="12" x2="20" y2="12"></line>
          <line x1="4" y1="17" x2="20" y2="17"></line>
        </svg>
      </button>
    </div>
  </div>
</header>

<div class="mobile-drawer sm:hidden" data-mobile-menu hidden>
  <button type="button" class="mobile-drawer__backdrop" data-mobile-close aria-label={menuCloseLabel}></button>
  <aside
    id="mobile-nav-drawer"
    class="mobile-drawer__panel"
    role="dialog"
    aria-modal="true"
    aria-label={menuTitle}
    data-mobile-drawer
    tabindex="-1"
  >
    <div class="mobile-drawer__header">
      <p class="mobile-drawer__title">{menuTitle}</p>
      <button type="button" class="mobile-drawer__close" data-mobile-close aria-label={menuCloseLabel}>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="6" y1="6" x2="18" y2="18"></line>
          <line x1="18" y1="6" x2="6" y2="18"></line>
        </svg>
      </button>
    </div>

    <nav class="mobile-drawer__nav" aria-label={menuTitle}>
      {visibleNavLinks.map((link) => (
        <a
          href={link.href}
          class={`mobile-drawer__link ${isNavLinkActive(link.href, link.external) ? "is-active" : ""}`}
          target={link.external ? "_blank" : undefined}
          rel={link.external ? "noopener" : undefined}
          data-mobile-close
        >
          <span class="mobile-drawer__link-main">
            <span class="mobile-drawer__icon" aria-hidden="true">
              {link.key === "library" && (
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M4 6.5a2.5 2.5 0 0 1 2.5-2.5H20v15H6.5A2.5 2.5 0 0 0 4 21.5z"></path>
                  <path d="M8 4v15"></path>
                </svg>
              )}
              {link.key === "docs" && (
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M14 3H6a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"></path>
                  <polyline points="14 3 14 9 20 9"></polyline>
                </svg>
              )}
              {link.key === "lab" && (
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M10 2v5l-5.5 9.5A2 2 0 0 0 6.2 20h11.6a2 2 0 0 0 1.7-3.5L14 7V2"></path>
                  <path d="M8.5 13h7"></path>
                </svg>
              )}
              {link.key === "showcase" && (
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="2" y="3" width="20" height="14" rx="2"></rect>
                  <path d="M8 21h8M12 17v4"></path>
                </svg>
              )}
              {link.key === "build" && (
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="3" y="3" width="8" height="8" rx="1.5"></rect>
                  <rect x="13" y="3" width="8" height="8" rx="1.5"></rect>
                  <rect x="8" y="13" width="8" height="8" rx="1.5"></rect>
                </svg>
              )}
              {link.key === "styleforge" && (
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="3"></circle>
                  <path d="M12 2v4M12 18v4M2 12h4M18 12h4M4.9 4.9l2.8 2.8M16.3 16.3l2.8 2.8M19.1 4.9l-2.8 2.8M7.7 16.3l-2.8 2.8"></path>
                </svg>
              )}
            </span>
            <span>{link.label}</span>
            {link.badge && <span class="nav-badge">{link.badge}</span>}
          </span>
          <span aria-hidden="true">↗</span>
        </a>
      ))}
      <a
        href="https://github.com/Foodhy/stealthis"
        target="_blank"
        rel="noopener noreferrer"
        class="mobile-drawer__link"
        data-mobile-close
      >
        <span class="mobile-drawer__link-main">
          <span class="mobile-drawer__icon" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"></path>
            </svg>
          </span>
          <span>GitHub</span>
        </span>
        <span aria-hidden="true">↗</span>
      </a>
    </nav>

    <label class="sr-only" for="mobile-language-select">{t("lang.label")}</label>
    <select
      id="mobile-language-select"
      class="mobile-drawer__lang"
      aria-label={t("lang.label")}
      data-language-select
      data-current-locale={locale}
    >
      {LOCALES.map((optionLocale) => (
        <option value={optionLocale}>{`${localeFlags[optionLocale]} ${localeOptionDisplay[optionLocale]}`}</option>
      ))}
    </select>
  </aside>
</div>

<style>
  .nav-link {
    @apply text-sm font-medium text-slate-400 hover:text-slate-100 transition-colors px-3 py-1.5 rounded-lg hover:bg-white/6;
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }

  .nav-link.is-active {
    color: rgb(241 245 249);
    border: 1px solid rgba(103, 183, 255, 0.38);
    background: linear-gradient(90deg, rgba(74, 146, 255, 0.2), rgba(120, 110, 255, 0.16));
    box-shadow: inset 0 0 0 1px rgba(56, 189, 248, 0.2);
  }

  .lang-select {
    width: 10rem;
    max-width: 10rem;
    min-width: 0;
    border-radius: 0.5rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.04);
    color: rgb(226 232 240);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.38rem 0.6rem;
    transition: border-color 160ms ease, background 160ms ease;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .lang-select:hover {
    border-color: rgba(147, 197, 253, 0.4);
    background: rgba(255, 255, 255, 0.08);
  }

  .lang-select:focus-visible {
    outline: 2px solid rgba(103, 183, 255, 0.55);
    outline-offset: 1px;
  }

  .nav-badge {
    display: inline-block;
    font-size: 0.5rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    padding: 0.15em 0.4em;
    border-radius: 3px;
    background: #ef4444;
    color: #fff;
    line-height: 1.4;
    transform: rotate(-8deg);
    transform-origin: center;
    vertical-align: middle;
    margin-bottom: 2px;
  }

  .mobile-menu-trigger {
    display: inline-flex;
  }

  @media (min-width: 640px) {
    .mobile-menu-trigger {
      display: none !important;
    }
  }

  .mobile-drawer {
    position: fixed;
    inset: 0;
    z-index: 80;
  }

  .mobile-drawer__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(2, 6, 23, 0.72);
    opacity: 0;
    transition: opacity 200ms ease;
    border: 0;
  }

  .mobile-drawer__panel {
    position: absolute;
    top: 0;
    right: 0;
    height: 100%;
    width: min(86vw, 20rem);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1rem;
    border-left: 1px solid rgba(103, 183, 255, 0.24);
    background:
      radial-gradient(circle at 25% 18%, rgba(103, 183, 255, 0.23), transparent 38%),
      radial-gradient(circle at 78% 82%, rgba(149, 117, 255, 0.22), transparent 44%),
      linear-gradient(180deg, rgba(10, 18, 42, 0.97), rgba(7, 12, 28, 0.97));
    backdrop-filter: blur(14px);
    transform: translateX(100%);
    transition: transform 220ms cubic-bezier(0.2, 0.8, 0.2, 1);
    outline: none;
  }

  .mobile-drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.09);
  }

  .mobile-drawer__title {
    margin: 0;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgb(158 177 224);
  }

  .mobile-drawer__close {
    width: 2rem;
    height: 2rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.5rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.04);
    color: rgb(203 213 225);
  }

  .mobile-drawer__nav {
    display: grid;
    gap: 0.55rem;
  }

  .mobile-drawer__link-main {
    display: inline-flex;
    align-items: center;
    gap: 0.58rem;
  }

  .mobile-drawer__icon {
    width: 1.55rem;
    height: 1.55rem;
    border-radius: 0.45rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: rgb(188 214 255);
    border: 1px solid rgba(103, 183, 255, 0.34);
    background: linear-gradient(135deg, rgba(103, 183, 255, 0.2), rgba(149, 117, 255, 0.2));
    flex-shrink: 0;
  }

  .mobile-drawer__link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    text-decoration: none;
    color: rgb(233 240 255);
    padding: 0.7rem 0.8rem;
    border-radius: 0.7rem;
    border: 1px solid rgba(129, 161, 237, 0.31);
    background: linear-gradient(90deg, rgba(80, 129, 245, 0.12), rgba(92, 80, 198, 0.1));
    font-size: 0.92rem;
    font-weight: 500;
    transition: background 160ms ease, border-color 160ms ease, color 160ms ease;
  }

  .mobile-drawer__link:hover {
    color: rgb(255 255 255);
    background: linear-gradient(90deg, rgba(96, 155, 255, 0.2), rgba(133, 98, 255, 0.2));
    border-color: rgba(112, 164, 255, 0.52);
  }

  .mobile-drawer__link.is-active {
    color: rgb(255 255 255);
    border-color: rgba(120, 182, 255, 0.62);
    background: linear-gradient(90deg, rgba(96, 155, 255, 0.3), rgba(133, 98, 255, 0.24));
    box-shadow: inset 0 0 0 1px rgba(56, 189, 248, 0.25);
  }

  .mobile-drawer__link.is-active .mobile-drawer__icon {
    color: rgb(230 243 255);
    border-color: rgba(120, 182, 255, 0.74);
    background: linear-gradient(135deg, rgba(99, 167, 255, 0.32), rgba(149, 117, 255, 0.3));
  }

  .mobile-drawer__lang {
    margin-top: auto;
    width: 100%;
    border-radius: 0.75rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.05);
    color: rgb(226 232 240);
    font-size: 0.84rem;
    font-weight: 600;
    padding: 0.72rem 0.9rem;
    text-align: left;
    appearance: none;
  }

  .mobile-drawer.is-open .mobile-drawer__backdrop {
    opacity: 1;
  }

  .mobile-drawer.is-open .mobile-drawer__panel {
    transform: translateX(0);
  }

  :global(body.mobile-nav-open) {
    overflow: hidden;
  }
</style>

<script define:vars={{ locales: LOCALES, defaultLocale: DEFAULT_LOCALE, localeStorageKey: LOCALE_STORAGE_KEY }}>
  const splitLocaleFromPath = (pathname) => {
    const parts = pathname.split("/");
    const maybeLocale = parts[1];

    if (locales.includes(maybeLocale) && maybeLocale !== defaultLocale) {
      const barePath = `/${parts.slice(2).join("/")}` || "/";
      return {
        barePath: barePath === "/" ? "/" : barePath.replace(/\/$/, ""),
      };
    }

    return { barePath: pathname || "/" };
  };

  const toLocalizedPath = (locale, barePath) => {
    if (locale === defaultLocale) return barePath;
    if (barePath === "/") return `/${locale}/`;
    return `/${locale}${barePath}`;
  };

  const switchLocale = (targetLocale) => {
    if (!locales.includes(targetLocale)) return;
    localStorage.setItem(localeStorageKey, targetLocale);

    const { barePath } = splitLocaleFromPath(window.location.pathname);
    const nextPath = toLocalizedPath(targetLocale, barePath);

    if (nextPath !== window.location.pathname) {
      window.location.assign(`${nextPath}${window.location.search}${window.location.hash}`);
    }
  };

  document.querySelectorAll("[data-language-select]").forEach((selectEl) => {
    if (!(selectEl instanceof HTMLSelectElement)) return;
    const currentLocale = selectEl.dataset.currentLocale;
    if (currentLocale && locales.includes(currentLocale)) {
      selectEl.value = currentLocale;
    }

    selectEl.addEventListener("change", () => {
      switchLocale(selectEl.value);
    });
  });

  const menuButton = document.querySelector("[data-mobile-menu-button]");
  const menu = document.querySelector("[data-mobile-menu]");
  const menuPanel = menu?.querySelector("[data-mobile-drawer]");
  const closeTriggers = menu?.querySelectorAll("[data-mobile-close]");
  const mq = window.matchMedia("(min-width: 640px)");

  const closeMenu = (immediate = false) => {
    if (!(menu instanceof HTMLElement)) return;
    if (!(menuButton instanceof HTMLElement)) return;

    menu.classList.remove("is-open");
    menuButton.setAttribute("aria-expanded", "false");
    document.body.classList.remove("mobile-nav-open");

    if (immediate) {
      menu.hidden = true;
      return;
    }

    window.setTimeout(() => {
      if (!menu.classList.contains("is-open")) menu.hidden = true;
    }, 220);
  };

  const openMenu = () => {
    if (!(menu instanceof HTMLElement)) return;
    if (!(menuButton instanceof HTMLElement)) return;

    menu.hidden = false;
    menuButton.setAttribute("aria-expanded", "true");
    document.body.classList.add("mobile-nav-open");

    requestAnimationFrame(() => {
      menu.classList.add("is-open");
      if (menuPanel instanceof HTMLElement) menuPanel.focus();
    });
  };

  if (menuButton instanceof HTMLButtonElement && menu instanceof HTMLElement) {
    menuButton.addEventListener("click", () => {
      const expanded = menuButton.getAttribute("aria-expanded") === "true";
      if (expanded) {
        closeMenu();
      } else {
        openMenu();
      }
    });
  }

  closeTriggers?.forEach((el) => {
    el.addEventListener("click", () => closeMenu());
  });

  window.addEventListener("keydown", (event) => {
    if (event.key === "Escape") closeMenu();
  });

  mq.addEventListener("change", (event) => {
    if (event.matches) closeMenu(true);
  });
</script>
