---
import VibeApp from "../components/VibeApp";
import "../styles/global.css";

const homeUrl = import.meta.env.DEV ? "http://localhost:4321" : "https://stealthis.dev";
const description =
  "Vibe — AI-assisted project builder. Chat with local LLMs to generate and write project files.";
const canonicalURL = new URL("/", Astro.site ?? "https://vibe.stealthis.dev").toString();
---

<!doctype html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="theme-color" content="#020617" />
  <link rel="canonical" href={canonicalURL} />
  <title>Vibe — StealThis.dev</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body class="h-screen overflow-hidden bg-slate-950 text-slate-100">
  <VibeApp client:only="react" />
</body>
</html>
