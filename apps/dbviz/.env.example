# Runtime defaults for DBViz UI
DBVIZ_SCHEMA_PROVIDER=local
DBVIZ_LOCAL_ENGINE=docker

# Local Docker validation settings (apps/dbviz/scripts/validate-schemas.ts)
DBVIZ_DOCKER_IMAGE=postgres:16-alpine
DBVIZ_DOCKER_PORT=55432
DBVIZ_DOCKER_DB=dbviz
DBVIZ_DOCKER_USER=postgres
DBVIZ_DOCKER_PASSWORD=postgres

# Supabase import scaffold (apps/dbviz/scripts/supabase-import.ts)
# Example direct Postgres URL format:
# postgres://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
DBVIZ_SUPABASE_DB_URL=
DBVIZ_SUPABASE_SCHEMA=public
DBVIZ_SUPABASE_OUTPUT_DIR=apps/dbviz/.imports
DBVIZ_SUPABASE_PROJECT_URL=https://<project-ref>.supabase.co
DBVIZ_SUPABASE_DRAFT_SLUG=
DBVIZ_SUPABASE_DRAFT_TITLE=
DBVIZ_SUPABASE_DRAFT_DESCRIPTION=
DBVIZ_SUPABASE_DRAFT_OVERWRITE=false
