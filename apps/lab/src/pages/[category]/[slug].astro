    .db-schema-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 1.15rem;
      padding: 0.1rem 0.2rem;
      border-radius: 0.25rem;
      font-size: 0.58rem;
      font-weight: 700;
      letter-spacing: 0.03em;
      line-height: 1;
      border: 1px solid transparent;
    }

    .db-schema-badge.pk {
      color: #fde68a;
      border-color: rgba(250, 204, 21, 0.4);
      background: rgba(146, 64, 14, 0.35);
    }

    .db-schema-badge.fk {
      color: #ddd6fe;
      border-color: rgba(196, 181, 253, 0.44);
      background: rgba(76, 29, 149, 0.35);
    }

    .db-schema-name {
      color: #e2e8f0;
    }

    .db-schema-type {
      color: #67e8f9;
      font-size: 0.66rem;
      text-transform: lowercase;
    }

    .db-schema-ref {
      border-top: 1px dashed rgba(148, 163, 184, 0.14);
      padding: 0.42rem 0.65rem 0.5rem 2.85rem;
      font-family: "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
      font-size: 0.66rem;
      color: #7dd3fc;
      background: rgba(2, 132, 199, 0.08);
    }

    .db-sql-wrap {
      display: grid;
      gap: 0.7rem;
      padding: 0.75rem;
    }

    .db-sql-group {
      border: 1px solid rgba(148, 163, 184, 0.18);
      border-radius: 0.75rem;
      background: rgba(2, 6, 23, 0.55);
      overflow: hidden;
    }

    .db-sql-group summary {
      list-style: none;
      cursor: pointer;
      padding: 0.6rem 0.75rem;
      font-size: 0.78rem;
      font-weight: 700;
      color: #cbd5e1;
      border-bottom: 1px solid rgba(148, 163, 184, 0.14);
      background: rgba(15, 23, 42, 0.4);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.5rem;
    }

    .db-empty {
      padding: 1rem;
      color: #94a3b8;
      font-size: 0.8rem;
    }

    .db-copy-btn {
      border: 1px solid rgba(148, 163, 184, 0.3);
      border-radius: 0.5rem;
      background: rgba(15, 23, 42, 0.75);
      color: #cbd5e1;
      padding: 0.25rem 0.55rem;
      font-size: 0.7rem;
      font-weight: 700;
      line-height: 1;
      cursor: pointer;
      transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
    }

    .db-copy-btn:hover {
      background: rgba(8, 47, 73, 0.9);
      border-color: rgba(34, 211, 238, 0.5);
      color: #ecfeff;
    }

    @media (max-width: 1040px) {
      .db-main {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body>
  {isDatabaseSchema ? (
    <div class="db-shell">
      <header class="db-toolbar">
        <div>
          <p>{meta.title}</p>
          <small>{meta.category} · SQL + ERD viewer</small>
        </div>
        <div class="db-toolbar-actions">
          <a href={wwwUrl} target="_blank" rel="noopener">View Resource</a>
          <a href="/">Back to Lab</a>
        </div>
      </header>

      <main class="db-main">
        <section class="db-panel">
          <div class="db-panel-head">
            <h2>Diagram Views</h2>
            <div class="db-view-switch" role="tablist" aria-label="Database diagram views">
              <button
                type="button"
                class="db-view-btn"
                data-db-view="erd"
                aria-pressed="false"
              >
                ERD
              </button>
              <button
                type="button"
                class="db-view-btn"
                data-db-view="schema"
                aria-pressed="false"
              >
                Schema
              </button>
              <button
                type="button"
                class="db-view-btn active"
                data-db-view="interactive"
                aria-pressed="true"
              >
                ✦ Interactive
              </button>
            </div>
          </div>

          <div class="db-diagram-panel" data-db-diagram-panel="erd">
            <div class="db-diagram-wrap">
              {diagramMmd ? (
                <div class="mermaid" id="lab-dbviz-mermaid">{diagramMmd}</div>
              ) : schemaDbml ? (
                <>
                  <p class="db-empty">No Mermaid diagram found. Showing DBML source.</p>
                  <pre>{schemaDbml}</pre>
                </>
              ) : (
                <p class="db-empty">No diagram snippet found. Add <code>diagram.mmd</code> or <code>schema.dbml</code>.</p>
              )}
            </div>
          </div>

          <div class="db-diagram-panel" data-db-diagram-panel="schema" hidden>
            <div class="db-diagram-wrap">
              {schemaTables.length > 0 ? (
                <div class="db-schema-grid">
                  {schemaTables.map((table) => (
                    <article class="db-schema-table">
                      <header class="db-schema-table-head">
                        <strong>{table.name}</strong>
                        <span>{table.columns.length} cols</span>
                      </header>
                      <ul class="db-schema-columns">
                        {table.columns.map((column) => (
                          <>
                            <li class="db-schema-row">
                              <span class="db-schema-badges">
                                {column.isPrimaryKey ? <span class="db-schema-badge pk">PK</span> : null}
                                {column.isForeignKey ? <span class="db-schema-badge fk">FK</span> : null}
                              </span>
                              <span class="db-schema-name">{column.name}</span>
                              <span class="db-schema-type">{column.type}</span>
                            </li>
                            {column.references ? <li class="db-schema-ref">→ {column.references}</li> : null}
                          </>
                        ))}
                      </ul>
                    </article>
                  ))}
                </div>
              ) : schemaDbml ? (
                <>
                  <p class="db-empty">Could not parse <code>schema.sql</code>. Showing <code>schema.dbml</code>.</p>
                  <pre>{schemaDbml}</pre>
                </>
              ) : schemaSql ? (
                <>
                  <p class="db-empty">Could not parse <code>schema.sql</code> into table cards. Showing raw SQL.</p>
                  <pre>{schemaSql}</pre>
                </>
              ) : (
                <p class="db-empty">Missing <code>schema.sql</code> for Schema Diagram view.</p>
              )}
            </div>
          </div>

          <div class="db-diagram-panel" data-db-diagram-panel="interactive" hidden>
            <div class="db-interactive-wrap">
              <div class="db-interactive-toolbar">
                <span class="db-interactive-hint">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15" />
                  </svg>
                  Drag tables to reposition
                </span>
                <div class="db-interactive-btns">
                  <button type="button" id="db-anim-toggle" class="db-interactive-btn active">✦ Animated</button>
                  <button type="button" id="db-reset-btn" class="db-interactive-btn">Reset</button>
                </div>
              </div>
              <div class="db-interactive-canvas-wrap" id="db-interactive-diagram"></div>
              <div class="db-interactive-legend">
                <span class="db-interactive-legend-item"><span class="db-interactive-legend-pk">PK</span> Primary key</span>
                <span class="db-interactive-legend-item"><span class="db-interactive-legend-fk">FK</span> Foreign key</span>
                <span class="db-interactive-legend-item"><span class="db-interactive-legend-line-dashed"></span> Relation</span>
                <span class="db-interactive-legend-item"><span class="db-interactive-legend-line-active"></span> Active relation</span>
                <span class="db-interactive-stats" id="db-diagram-stats"></span>
              </div>
            </div>
          </div>
        </section>

        <section class="db-panel">
          <h2>SQL Snippets</h2>
          <div class="db-sql-wrap">
            <details class="db-sql-group" open>
              <summary>
                <span>schema.sql</span>
                {schemaSql ? (
                  <button type="button" class="db-copy-btn" data-copy-target="db-schema-sql">Copy</button>
                ) : null}
              </summary>
              {schemaSql ? <pre id="db-schema-sql">{schemaSql}</pre> : <p class="db-empty">Missing schema.sql</p>}
            </details>

            <details class="db-sql-group" open>
              <summary>
                <span>seed.sql</span>
                {seedSql ? (
                  <button type="button" class="db-copy-btn" data-copy-target="db-seed-sql">Copy</button>
                ) : null}
              </summary>
              {seedSql ? <pre id="db-seed-sql">{seedSql}</pre> : <p class="db-empty">Missing seed.sql</p>}
            </details>

            <details class="db-sql-group" open>
              <summary>
                <span>queries.sql</span>
                {queriesSql ? (
                  <button type="button" class="db-copy-btn" data-copy-target="db-queries-sql">Copy</button>
                ) : null}
              </summary>
              {queriesSql ? <pre id="db-queries-sql">{queriesSql}</pre> : <p class="db-empty">Missing queries.sql</p>}
            </details>
          </div>
        </section>
      </main>
    </div>
  ) : (
    <>
      <div class="lab-overlay">
        {hasVariants && (
          <>
            {demoVariants.map((variant, index) => (
              <button
                type="button"
                class:list={["lab-btn", index === 0 && "active"]}
                data-demo-variant={variant.id}
                aria-pressed={index === 0 ? "true" : "false"}
              >
                {variant.label}
              </button>
            ))}
          </>
        )}
        <span style="color:#475569;font-size:0.7rem;font-family:system-ui">
          {meta.title}
        </span>
        <a href={wwwUrl} target="_blank" rel="noopener" class="lab-btn">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
          </svg>
          View Code
        </a>
        <a href="/" class="lab-btn">
          ← Lab
        </a>
      </div>

      {defaultSrcdoc ? (
        <iframe
          id="demo-frame"
          class="demo-frame"
          srcdoc={defaultSrcdoc}
          title={`${meta.title} demo`}
          sandbox="allow-scripts allow-same-origin allow-forms"
          loading="lazy"
        />
      ) : (
        <div style="display:grid;place-items:center;height:100vh;color:#475569;font-family:system-ui">
          No demo available for this resource.
        </div>
      )}

      {hasVariants && (
        <script is:inline define:vars={{ demoVariants }}>
          const frame = document.getElementById("demo-frame");
          const buttons = Array.from(document.querySelectorAll("[data-demo-variant]"));
          const variants = new Map(demoVariants.map((variant) => [variant.id, variant.srcdoc]));
          const defaultVariantId = demoVariants[0]?.id ?? null;

          if (frame && defaultVariantId) {
            const syncButtons = (activeVariant) => {
              for (const button of buttons) {
                const isActive = button.dataset.demoVariant === activeVariant;
                button.classList.toggle("active", isActive);
                button.setAttribute("aria-pressed", String(isActive));
              }
            };

            const setVariant = (variantId, updateUrl = true) => {
              const nextSrcdoc = variants.get(variantId);
              if (!nextSrcdoc) return;

              frame.srcdoc = nextSrcdoc;
              syncButtons(variantId);

              if (!updateUrl) return;

              const params = new URLSearchParams(window.location.search);
              if (variantId === defaultVariantId) {
                params.delete("implementation");
                params.delete("impl");
              } else {
                params.set("implementation", variantId);
                params.delete("impl");
              }

              const search = params.toString();
              const nextUrl = `${window.location.pathname}${search ? `?${search}` : ""}${window.location.hash}`;
              window.history.replaceState({}, "", nextUrl);
            };

            const initialParams = new URLSearchParams(window.location.search);
            const requestedVariant =
              initialParams.get("implementation") ?? initialParams.get("impl") ?? defaultVariantId;
            setVariant(variants.has(requestedVariant) ? requestedVariant : defaultVariantId, false);

            for (const button of buttons) {
              button.addEventListener("click", () => {
                const variantId = button.dataset.demoVariant;
                if (variantId) setVariant(variantId);
              });
            }
          }
        </script>
      )}
    </>
  )}

  {isDatabaseSchema && diagramMmd && (
    <script type="module" is:inline>
      import mermaid from "https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs";

      mermaid.initialize({
        startOnLoad: true,
        securityLevel: "loose",
        theme: "dark",
      });

      mermaid.run({ querySelector: "#lab-dbviz-mermaid" });
    </script>
  )}

  {isDatabaseSchema && diagramMmd && (
    <script is:inline define:vars={{ diagramMmd }}>
    (function () {
      /* ── Constants ─────────────────────────────── */
      const TABLE_W   = 220;
      const ROW_H     = 28;
      const HEADER_H  = 38;
      const PAD       = 60;
      const COL_GAP   = 80;
      const ROW_GAP   = 60;
      const COLORS    = [
        "#58a6ff","#7ee787","#e3b341","#bc8cff","#ff7b72",
        "#39d353","#f78166","#a5d6ff","#d2a8ff","#ffa657",
      ];
      const SVG_NS    = "http://www.w3.org/2000/svg";

      /* ── State ─────────────────────────────────── */
      let tables    = [];
      let relations = [];
      let selected  = null;
      let animated  = true;
      let initialPositions = [];

      /* ── Parser ────────────────────────────────── */
      function parseMermaidER(src) {
        const tbls = [], rels = [];
        let inTable = null, cols = [];
        for (const rawLine of src.split("\n")) {
          const line = rawLine.trim();
          if (!line || /^erDiagram/i.test(line)) continue;
          const tStart = line.match(/^(\w+)\s*\{/);
          if (tStart) { inTable = tStart[1]; cols = []; continue; }
          if (line === "}") {
            if (inTable) { tbls.push({ id: inTable, name: inTable, columns: cols }); inTable = null; cols = []; }
            continue;
          }
          if (inTable) {
            const m = line.match(/^(\S+)\s+(\S+)(.*)/);
            if (m) {
              const up = m[3].toUpperCase();
              cols.push({ name: m[2], type: m[1], pk: up.includes("PK"), fk: up.includes("FK"), nullable: !up.includes("PK") && !up.includes("NOT NULL") });
            }
            continue;
          }
          const r = line.match(/^(\w+)\s+([|o}{]{2,3}--[|o}{]{2,3})\s+(\w+)\s*(?::\s*(.*))?$/);
          if (r) rels.push({ from: r[1], to: r[3], label: (r[4] || "").replace(/["']/g, "").trim() });
        }
        return { tables: tbls, relations: rels };
      }

      /* ── Layout ────────────────────────────────── */
      function layout(rawTables) {
        const cols_ = Math.ceil(Math.sqrt(rawTables.length));
        return rawTables.map((t, i) => {
          const col = i % cols_, row = Math.floor(i / cols_);
          const h = HEADER_H + t.columns.length * ROW_H;
          return { ...t, color: COLORS[i % COLORS.length],
            x: PAD + col * (TABLE_W + COL_GAP),
            y: PAD + row * (h + ROW_GAP + 40) };
        });
      }

      /* ── Geometry ──────────────────────────────── */
      function tH(t) { return HEADER_H + t.columns.length * ROW_H; }

      function edgePoints(ft, tt) {
        const fCx = ft.x + TABLE_W / 2, tCx = tt.x + TABLE_W / 2;
        return {
          ax: fCx < tCx ? ft.x + TABLE_W : ft.x,
          ay: ft.y + tH(ft) / 2,
          bx: fCx < tCx ? tt.x : tt.x + TABLE_W,
          by: tt.y + tH(tt) / 2,
        };
      }

      function bezier(ax, ay, bx, by) {
        const dx = Math.abs(bx - ax), cx = Math.min(60, dx * 0.5);
        const ax2 = ax < bx ? ax + cx : ax - cx;
        const bx2 = ax < bx ? bx - cx : bx + cx;
        return `M ${ax} ${ay} C ${ax2} ${ay}, ${bx2} ${by}, ${bx} ${by}`;
      }

      /* ── SVG helpers ───────────────────────────── */
      function el(tag, attrs = {}, children = []) {
        const e = document.createElementNS(SVG_NS, tag);
        for (const [k, v] of Object.entries(attrs)) e.setAttribute(k, v);
        for (const c of children) if (c) e.appendChild(c);
        return e;
      }
      function txt(tag, attrs, text) {
        const e = el(tag, attrs);
        e.textContent = text;
        return e;
      }

      /* ── Render ────────────────────────────────── */
      function render() {
        const host = document.getElementById("db-interactive-diagram");
        if (!host) return;

        const canvasW = Math.max(700, ...tables.map(t => t.x + TABLE_W + PAD));
        const canvasH = Math.max(460, ...tables.map(t => t.y + tH(t) + PAD));

        const svg = el("svg", { width: canvasW, height: canvasH });

        /* Grid */
        const defs = el("defs");
        const pat = el("pattern", { id: "db-ig-grid", width: 24, height: 24, patternUnits: "userSpaceOnUse" });
        pat.appendChild(el("path", { d: "M 24 0 L 0 0 0 24", fill: "none", stroke: "#1e293b", "stroke-width": "0.5" }));
        defs.appendChild(pat);
        svg.appendChild(defs);
        svg.appendChild(el("rect", { width: "100%", height: "100%", fill: "url(#db-ig-grid)" }));

        /* Relations */
        for (const rel of relations) {
          const ft = tables.find(t => t.id === rel.from);
          const tt = tables.find(t => t.id === rel.to);
          if (!ft || !tt) continue;
          const isActive = selected === rel.from || selected === rel.to;
          const { ax, ay, bx, by } = edgePoints(ft, tt);
          const stroke = isActive ? "#3b82f6" : "#334155";
          const path = el("path", {
            d: bezier(ax, ay, bx, by),
            fill: "none", stroke, "stroke-width": isActive ? 2 : 1.5,
            opacity: isActive ? 1 : 0.7,
            ...(animated ? { "stroke-dasharray": "6 3", class: "db-animate-dash" } : {}),
          });
          svg.appendChild(el("circle", { cx: ax, cy: ay, r: 3, fill: isActive ? "#3b82f6" : "#475569" }));
          svg.appendChild(el("circle", { cx: bx, cy: by, r: 3, fill: isActive ? "#3b82f6" : "#475569" }));
          svg.appendChild(path);
          if (rel.label) {
            const lx = (ax + bx) / 2, ly = (ay + by) / 2;
            svg.appendChild(txt("text", {
              x: lx, y: ly - 7,
              fill: isActive ? "#93c5fd" : "#64748b",
              "font-size": 10, "text-anchor": "middle", "font-family": "monospace"
            }, rel.label));
          }
        }

        /* Tables */
        for (const t of tables) {
          const g = el("g", { transform: `translate(${t.x},${t.y})`, style: "cursor:grab;user-select:none" });
          const h = tH(t);

          /* shadow */
          g.appendChild(el("rect", { x: 4, y: 4, width: TABLE_W, height: h, rx: 10, fill: "rgba(0,0,0,0.55)", style: "filter:blur(3px)" }));

          /* body */
          const isSelected = selected === t.id;
          g.appendChild(el("rect", { width: TABLE_W, height: h, rx: 10, fill: "#0a0f1e", stroke: isSelected ? t.color : "#1e293b", "stroke-width": isSelected ? 2 : 1 }));

          /* header */
          g.appendChild(el("rect", { width: TABLE_W, height: HEADER_H, rx: 10, fill: t.color + "22" }));
          g.appendChild(el("rect", { y: HEADER_H - 10, width: TABLE_W, height: 10, fill: t.color + "22" }));
          g.appendChild(el("rect", { y: HEADER_H - 1, width: TABLE_W, height: 1, fill: isSelected ? t.color : t.color + "44" }));
          /* left accent */
          g.appendChild(el("rect", { width: 3, height: h, rx: 10, fill: t.color, opacity: isSelected ? 1 : 0.6 }));
          g.appendChild(el("rect", { y: HEADER_H, width: 3, height: h - HEADER_H, fill: t.color, opacity: isSelected ? 0.8 : 0.3 }));

          /* table name */
          g.appendChild(txt("text", {
            x: TABLE_W / 2, y: HEADER_H / 2 + 6,
            "text-anchor": "middle", fill: t.color,
            "font-size": 13, "font-weight": "bold", "font-family": "monospace",
          }, t.name));

          /* columns */
          t.columns.forEach((col, i) => {
            const cy = HEADER_H + i * ROW_H;
            if (i % 2 === 1) g.appendChild(el("rect", { y: cy, width: TABLE_W, height: ROW_H, fill: "rgba(255,255,255,0.025)" }));
            if (col.pk || col.fk) g.appendChild(txt("text", {
              x: 12, y: cy + ROW_H / 2 + 4,
              fill: col.pk ? "#e3b341" : "#bc8cff",
              "font-size": 9, "font-weight": "bold", "font-family": "monospace"
            }, col.pk ? "PK" : "FK"));
            g.appendChild(txt("text", {
              x: (col.pk || col.fk) ? 36 : 12, y: cy + ROW_H / 2 + 4,
              fill: col.nullable && !col.pk ? "#94a3b8" : "#e2e8f0",
              "font-size": 11, "font-family": "monospace"
            }, col.name));
            g.appendChild(txt("text", {
              x: TABLE_W - 10, y: cy + ROW_H / 2 + 4,
              "text-anchor": "end", fill: "#475569",
              "font-size": 10, "font-family": "monospace"
            }, col.type));
          });

          /* drag + click */
          let dragStart = null, moved = false;
          g.addEventListener("mousedown", e => {
            e.stopPropagation();
            dragStart = { x: e.clientX, y: e.clientY }; moved = false;
            const onMove = me => {
              if (!dragStart) return;
              const dx = me.clientX - dragStart.x, dy = me.clientY - dragStart.y;
              if (Math.abs(dx) > 2 || Math.abs(dy) > 2) moved = true;
              t.x += dx; t.y += dy;
              dragStart = { x: me.clientX, y: me.clientY };
              render();
            };
            const onUp = () => {
              if (!moved) { selected = selected === t.id ? null : t.id; render(); }
              dragStart = null;
              window.removeEventListener("mousemove", onMove);
              window.removeEventListener("mouseup", onUp);
            };
            window.addEventListener("mousemove", onMove);
            window.addEventListener("mouseup", onUp);
          });
          /* touch */
          g.addEventListener("touchstart", e => {
            e.stopPropagation();
            const touch = e.touches[0]; if (!touch) return;
            dragStart = { x: touch.clientX, y: touch.clientY }; moved = false;
            const onMove = te => {
              const t2 = te.touches[0]; if (!t2 || !dragStart) return;
              const dx = t2.clientX - dragStart.x, dy = t2.clientY - dragStart.y;
              moved = true; t.x += dx; t.y += dy;
              dragStart = { x: t2.clientX, y: t2.clientY }; render();
            };
            const onEnd = () => {
              if (!moved) { selected = selected === t.id ? null : t.id; render(); }
              dragStart = null;
              window.removeEventListener("touchmove", onMove);
              window.removeEventListener("touchend", onEnd);
            };
            window.addEventListener("touchmove", onMove, { passive: true });
            window.addEventListener("touchend", onEnd);
          }, { passive: true });

          svg.appendChild(g);
        }

        /* deselect on canvas click */
        svg.addEventListener("click", e => {
          if (e.target === svg) { selected = null; render(); }
        });

        /* swap svg */
        host.innerHTML = "";
        host.appendChild(svg);

        /* stats */
        const stats = document.getElementById("db-diagram-stats");
        if (stats) stats.textContent = `${tables.length} table${tables.length !== 1 ? "s" : ""} · ${relations.length} relation${relations.length !== 1 ? "s" : ""}`;
      }

      /* ── Init ──────────────────────────────────── */
      function init() {
        try {
          const parsed = parseMermaidER(diagramMmd);
          if (!parsed.tables.length) {
            const host = document.getElementById("db-interactive-diagram");
            if (host) host.innerHTML = '<div class="db-interactive-error">No tables detected in diagram source.<br><small>Ensure diagram.mmd uses erDiagram format.</small></div>';
            return;
          }
          tables = layout(parsed.tables);
          initialPositions = tables.map(t => ({ id: t.id, x: t.x, y: t.y }));
          relations = parsed.relations;
          render();
        } catch(e) {
          const host = document.getElementById("db-interactive-diagram");
          if (host) host.innerHTML = `<div class="db-interactive-error">Error parsing diagram: ${e.message}</div>`;
        }
      }

      /* ── Controls ──────────────────────────────── */
      document.addEventListener("DOMContentLoaded", () => {
        init();

        const animBtn = document.getElementById("db-anim-toggle");
        if (animBtn) animBtn.addEventListener("click", () => {
          animated = !animated;
          animBtn.textContent = animated ? "✦ Animated" : "Static";
          animBtn.classList.toggle("active", animated);
          render();
        });

        const resetBtn = document.getElementById("db-reset-btn");
        if (resetBtn) resetBtn.addEventListener("click", () => {
          tables = layout(tables.map(({ id, name, columns, color }) => ({ id, name, columns, color })));
          selected = null;
          render();
        });
      });
    })();
    </script>
  )}

  {isDatabaseSchema && (
    <script is:inline>
      const viewButtons = Array.from(document.querySelectorAll("[data-db-view]"));
      const diagramPanels = Array.from(document.querySelectorAll("[data-db-diagram-panel]"));
      const defaultDiagramView = "interactive";

      const syncDiagramView = (nextView, updateUrl = true) => {
        for (const panel of diagramPanels) {
          const panelView = panel.getAttribute("data-db-diagram-panel");
          panel.hidden = panelView !== nextView;
        }

        for (const button of viewButtons) {
          const buttonView = button.getAttribute("data-db-view");
          const isActive = buttonView === nextView;
          button.classList.toggle("active", isActive);
          button.setAttribute("aria-pressed", String(isActive));
        }

        if (!updateUrl) return;

        const params = new URLSearchParams(window.location.search);
        if (nextView === defaultDiagramView) {
          params.delete("diagram");
          params.delete("view");
        } else {
          params.set("diagram", nextView);
          params.delete("view");
        }

        const search = params.toString();
        const nextUrl = `${window.location.pathname}${search ? `?${search}` : ""}${window.location.hash}`;
        window.history.replaceState({}, "", nextUrl);
      };

      const availableViews = new Set(
        diagramPanels
          .map((panel) => panel.getAttribute("data-db-diagram-panel"))
          .filter(Boolean)
      );
      const urlParams = new URLSearchParams(window.location.search);
      const requestedView =
        (urlParams.get("diagram") ?? urlParams.get("view") ?? defaultDiagramView).toLowerCase();

      syncDiagramView(availableViews.has(requestedView) ? requestedView : defaultDiagramView, false);

      for (const button of viewButtons) {
        button.addEventListener("click", () => {
          const nextView = button.getAttribute("data-db-view");
          if (!nextView) return;
          syncDiagramView(nextView);
        });
      }

      const copyButtons = document.querySelectorAll(".db-copy-btn");

      const copyFromTarget = async (button) => {
        const targetId = button.getAttribute("data-copy-target");
        if (!targetId) return;

        const source = document.getElementById(targetId);
        if (!source) return;

        const content = source.textContent ?? "";
        if (!content.trim()) return;

        try {
          await navigator.clipboard.writeText(content);
        } catch {
          const selection = window.getSelection();
          const range = document.createRange();
          range.selectNodeContents(source);
          selection?.removeAllRanges();
          selection?.addRange(range);
          document.execCommand("copy");
          selection?.removeAllRanges();
        }

        const original = button.textContent;
        button.textContent = "Copied";
        window.setTimeout(() => {
          button.textContent = original;
        }, 1600);
      };

      for (const button of copyButtons) {
        button.addEventListener("click", async (event) => {
          event.preventDefault();
          event.stopPropagation();
          await copyFromTarget(button);
        });
      }
    </script>
  )}
</body>
</html>
