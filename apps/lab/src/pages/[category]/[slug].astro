      color: #e2e8f0;
    }

    .db-view-btn.active {
      color: #ecfeff;
      background: rgba(34, 211, 238, 0.2);
    }

    .db-diagram-panel[hidden] {
      display: none;
    }

    .db-diagram-wrap {
      padding: 1rem;
      overflow: auto;
      min-height: 30rem;
    }

    .db-diagram-wrap .mermaid {
      min-width: 28rem;
    }

    /* ─── Interactive Diagram ─────────────────────── */
    .db-interactive-wrap {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      padding: 0.75rem;
    }

    .db-interactive-toolbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

