---
import { existsSync, readFileSync } from "node:fs";
import path from "node:path";
import fg from "fast-glob";
import matter from "gray-matter";
import { SITE_URLS } from "../../lib/urls";
import "../../styles/global.css";

export async function getStaticPaths() {
  function buildReactSrcdoc(tsxCode: string): string | null {
    const scriptTagOpen = "<" + "script";
    const scriptTagClose = "</" + "script>";
    const directDefaultMatch = tsxCode.match(/export\s+default\s+function\s+([A-Za-z_$][\w$]*)/);
    const namedDefaultMatch = tsxCode.match(/export\s+default\s+([A-Za-z_$][\w$]*)\s*;?/);
    const componentName = directDefaultMatch?.[1] ?? namedDefaultMatch?.[1] ?? null;

    if (!componentName) return null;

    let code = tsxCode.trim();

    code = code.replace(/^\s*import[\s\S]*?from\s+["'][^"']+["'];?\s*$/gm, "");
    code = code.replace(/^\s*import\s+["'][^"']+["'];?\s*$/gm, "");
    code = code.replace(
      new RegExp(`export\\s+default\\s+function\\s+${componentName}\\b`),
      `function ${componentName}`
    );
    code = code.replace(
      new RegExp(`^\\s*export\\s+default\\s+${componentName}\\s*;?\\s*$`, "gm"),
      ""
    );
    code = code.replace(/^\s*export\s+(?=(const|function|class|let|var|type|interface)\b)/gm, "");

    const safeCode = code.trim().replace(/<\/script>/gi, "<\\/script>");

    return `<!doctype html>
<html>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
${scriptTagOpen} src="https://cdn.jsdelivr.net/npm/react@18/umd/react.development.js">${scriptTagClose}
${scriptTagOpen} src="https://cdn.jsdelivr.net/npm/react-dom@18/umd/react-dom.development.js">${scriptTagClose}
${scriptTagOpen} src="https://cdn.jsdelivr.net/npm/@babel/standalone@7/babel.min.js">${scriptTagClose}
${scriptTagOpen} src="https://cdn.tailwindcss.com">${scriptTagClose}
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body { min-height: 100%; background: #020617; }
</style>
</head>
<body>
<div id="root"></div>
${scriptTagOpen}>
const rootNode = document.getElementById("root");
const renderError = (error) => {
  if (!rootNode) return;
  const message = error instanceof Error ? \`\${error.name}: \${error.message}\` : String(error);
  rootNode.innerHTML = "";
  const pre = document.createElement("pre");
  pre.textContent = message;
  pre.style.cssText =
    "margin:24px;padding:16px;border-radius:12px;border:1px solid rgba(248,113,113,.28);background:#190b0f;color:#fecaca;font:12px/1.6 ui-monospace,SFMono-Regular,Menlo,monospace;white-space:pre-wrap;";
  rootNode.append(pre);
};

window.addEventListener("error", (event) => {
  renderError(event.error ?? event.message);
});

window.addEventListener("unhandledrejection", (event) => {
  renderError(event.reason);
});

const source = ${JSON.stringify(`const {
  useState,
  useEffect,
  useLayoutEffect,
  useRef,
  useCallback,
  useMemo,
  useReducer,
  useContext,
  createContext,
  Fragment,
  forwardRef,
  memo,
  useId,
  useDeferredValue,
  useTransition,
  useImperativeHandle,
  startTransition,
} = React;

${safeCode}

if (!document.getElementById("root")) {
  throw new Error("Missing #root mount node");
}

ReactDOM.createRoot(document.getElementById("root")).render(React.createElement(${componentName}));`)};;

try {
  const compiled = Babel.transform(source, {
    filename: "demo.tsx",
    sourceType: "script",
    presets: [
      ["typescript", { isTSX: true, allExtensions: true }],
      ["react", { runtime: "classic" }],
    ],
  }).code;
  new Function("React", "ReactDOM", compiled)(React, ReactDOM);
} catch (error) {
  renderError(error);
}
${scriptTagClose}
</body>
</html>`;
  }

  const CONTENT_DIR = path.resolve(process.cwd(), "../../packages/content");
  const files = await fg(path.join(CONTENT_DIR, "resources/*/index.mdx"));

  const paths = [];

  for (const file of files) {
    const raw = readFileSync(file, "utf-8");
    const { data } = matter(raw);

    if (!data.labRoute) continue;

    // labRoute is like "/web-animations/scroll-fade"
    const parts = data.labRoute.replace(/^\//, "").split("/");
    if (parts.length < 2) continue;

    const [category, slug] = parts;

    const snippetsDir = path.join(CONTENT_DIR, `resources/${data.slug}/snippets`);
    const htmlPath = path.join(snippetsDir, "html.html");
    const cssPath = path.join(snippetsDir, "style.css");
    const jsPath = path.join(snippetsDir, "script.js");
    const schemaSqlPath = path.join(snippetsDir, "schema.sql");
    const seedSqlPath = path.join(snippetsDir, "seed.sql");
    const queriesSqlPath = path.join(snippetsDir, "queries.sql");
    const diagramMmdPath = path.join(snippetsDir, "diagram.mmd");
    const schemaDbmlPath = path.join(snippetsDir, "schema.dbml");

    const html = existsSync(htmlPath) ? readFileSync(htmlPath, "utf-8") : null;
    const css = existsSync(cssPath) ? readFileSync(cssPath, "utf-8") : null;
    const js = existsSync(jsPath) ? readFileSync(jsPath, "utf-8") : null;
    const schemaSql = existsSync(schemaSqlPath) ? readFileSync(schemaSqlPath, "utf-8") : null;
    const seedSql = existsSync(seedSqlPath) ? readFileSync(seedSqlPath, "utf-8") : null;
    const queriesSql = existsSync(queriesSqlPath) ? readFileSync(queriesSqlPath, "utf-8") : null;
    const diagramMmd = existsSync(diagramMmdPath) ? readFileSync(diagramMmdPath, "utf-8") : null;
    const schemaDbml = existsSync(schemaDbmlPath) ? readFileSync(schemaDbmlPath, "utf-8") : null;

    const reactPath = path.join(snippetsDir, "react.tsx");
    const reactTsx = existsSync(reactPath) ? readFileSync(reactPath, "utf-8") : null;
    const reactSrcdoc = reactTsx ? buildReactSrcdoc(reactTsx) : null;

    paths.push({
      params: { category, slug },
      props: {
        meta: data,
        html,
        css,
        js,
        schemaSql,
        seedSql,
        queriesSql,
        diagramMmd,
        schemaDbml,
        reactSrcdoc,
      },
    });
  }

  return paths;
}

// biome-ignore lint/correctness/noUnusedVariables: Used in Astro template markup.
const { meta, html, css, js, schemaSql, seedSql, queriesSql, diagramMmd, schemaDbml, reactSrcdoc } =
  Astro.props;

const isDatabaseSchema = meta.category === "database-schemas";
const scriptTagOpen = "<" + "script";
const scriptTagClose = "</" + "script>";

type ParsedSchemaColumn = {
  name: string;
  type: string;
  isPrimaryKey: boolean;
  isForeignKey: boolean;
  references: string | null;
};

type ParsedSchemaTable = {
  name: string;
  columns: ParsedSchemaColumn[];
};

function normalizeIdentifier(raw: string): string {
  return raw.trim().replace(/^"|"$/g, "");
}

function normalizeQualifiedIdentifier(raw: string): string {
  return raw
    .split(".")
    .map((part) => normalizeIdentifier(part))
    .filter(Boolean)
    .join(".");
}

function extractColumnType(columnName: string, definition: string): string {
  const source = `${columnName} ${definition}`.trim();
  const match = source.match(
    /^"?(?:[A-Za-z_][\w$]*)"?\s+(.+?)(?=\s+(?:constraint\b|primary\s+key\b|references\b|not\s+null\b|null\b|default\b|check\b|unique\b|generated\b|collate\b)|$)/i
  );

  return match?.[1]?.trim() ?? "unknown";
}

function parseSchemaTables(source: string | null | undefined): ParsedSchemaTable[] {
  if (!source?.trim()) return [];

  const tables: ParsedSchemaTable[] = [];
  const tableRegex =
    /create\s+table\s+(?:if\s+not\s+exists\s+)?((?:"[^"]+"|[A-Za-z_][\w$]*)(?:\.(?:"[^"]+"|[A-Za-z_][\w$]*))?)\s*\(([\s\S]*?)\)\s*;/gi;

  for (const match of source.matchAll(tableRegex)) {
    const rawTableName = match[1] ?? "";
    const tableBody = match[2] ?? "";
    const tableName = normalizeQualifiedIdentifier(rawTableName).split(".").at(-1) ?? rawTableName;
    const columns: ParsedSchemaColumn[] = [];

    for (const line of tableBody.split(/\r?\n/)) {
      const normalizedLine = line.trim().replace(/,$/, "");
      if (!normalizedLine || normalizedLine.startsWith("--")) continue;
      if (/^(constraint|primary\s+key|foreign\s+key|unique|check)\b/i.test(normalizedLine))
        continue;

      const columnMatch = normalizedLine.match(/^("?[A-Za-z_][\w$]*"?)\s+(.+)$/);
      if (!columnMatch) continue;

      const columnName = normalizeIdentifier(columnMatch[1] ?? "");
      const columnDefinition = columnMatch[2] ?? "";

      const referenceMatch = columnDefinition.match(
        /\breferences\s+((?:"[^"]+"|[A-Za-z_][\w$]*)(?:\.(?:"[^"]+"|[A-Za-z_][\w$]*))?)\s*\(([^)]+)\)/i
      );

      const referenceTable = referenceMatch?.[1]
        ? normalizeQualifiedIdentifier(referenceMatch[1]).split(".").at(-1)
        : null;
      const referenceColumn = referenceMatch?.[2]
        ? normalizeIdentifier(referenceMatch[2].split(",")[0] ?? "")
        : null;
      const references =
        referenceTable && referenceColumn ? `${referenceTable}.${referenceColumn}` : null;

      columns.push({
        name: columnName,
        type: extractColumnType(columnName, columnDefinition),
        isPrimaryKey: /\bprimary\s+key\b/i.test(columnDefinition),
        isForeignKey: /\breferences\b/i.test(columnDefinition),
        references,
      });
    }

    if (columns.length > 0) {
      tables.push({ name: tableName, columns });
    }
  }

  return tables;
}

const schemaTables = parseSchemaTables(schemaSql);

let srcdoc = html ?? "";

if (!isDatabaseSchema && css && srcdoc) {
  srcdoc = srcdoc.replace(
    /<link[^>]*href=["'](?:\.\/)?style\.css["'][^>]*>/i,
    `<style>${css}</style>`
  );
}

if (!isDatabaseSchema && js && srcdoc) {
  srcdoc = srcdoc.replace(
    /<script([^>]*)src=["'](?:\.\/)?script\.js["']([^>]*)><\/script>/i,
    (_match, before, after) => {
      const attrs = `${before ?? ""} ${after ?? ""}`;
      const isModule = /\btype\s*=\s*["']module["']/i.test(attrs);
      return isModule
        ? `${scriptTagOpen} type="module">${js}${scriptTagClose}`
        : `${scriptTagOpen}>${js}${scriptTagClose}`;
    }
  );
}

const demoVariants = [
  ...(srcdoc ? [{ id: "vanilla", label: "Vanilla", srcdoc }] : []),
  ...(reactSrcdoc ? [{ id: "react", label: "React", srcdoc: reactSrcdoc }] : []),
];
const defaultSrcdoc = demoVariants[0]?.srcdoc ?? "";
const hasVariants = demoVariants.length > 1;

const wwwUrl = `${SITE_URLS.www}/r/${meta.slug}`;
const description = isDatabaseSchema
  ? (meta.description ?? "Relational schema viewer with SQL and ERD preview.")
  : (meta.description ?? "Runnable lab demo from StealThis.dev resources.");
const socialImageURL = new URL(
  "/og/lab.webp",
  Astro.site ?? "https://lab.stealthis.dev"
).toString();
---

<!doctype html>
<html lang="en" class:list={[isDatabaseSchema && "db-mode"]}>
<head>
