      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: center;
      gap: 0.5rem;
      padding: 0.48rem 0.65rem;
      border-top: 1px solid rgba(148, 163, 184, 0.08);
      font-family: "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
      font-size: 0.72rem;
      color: #cbd5e1;
