---
import "../styles/global.css";
// biome-ignore lint/correctness/noUnusedImports: Used in Astro component markup.
import StyleForgeStudio from "../components/StyleForgeStudio";

const wwwUrl = import.meta.env.DEV ? "http://localhost:4321" : "https://stealthis.dev";
const description =
  "StyleForge turns visual references into a downloadable HTML component kit with implementation guidance.";
const canonicalURL = new URL("/", Astro.site ?? "https://styleforge.stealthis.dev").toString();
// biome-ignore lint/correctness/noUnusedVariables: Used in Astro JSON-LD script.
const structuredData = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "StyleForge",
  description,
  url: canonicalURL,
  applicationCategory: "DesignApplication",
  isPartOf: {
    "@type": "WebSite",
    name: "StealThis.dev",
    url: "https://stealthis.dev/",
  },
});
---

<!doctype html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  <meta name="theme-color" content="#101e22" />
  <link rel="canonical" href={canonicalURL} />
  <meta property="og:title" content="StyleForge — StealThis.dev" />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content="https://stealthis.dev/social-card.webp" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="StyleForge — StealThis.dev" />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content="https://stealthis.dev/social-card.webp" />
  <script type="application/ld+json" set:html={structuredData} />
  <title>StyleForge — StealThis.dev</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <!-- Space Grotesk font -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700;800&display=swap"
    rel="stylesheet"
  />
  <!-- Material Symbols -->
  <link
    href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200"
    rel="stylesheet"
  />
</head>
<body>
  <!-- Top bar -->
  <header
    style="
      margin: 0.6rem 0.65rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
      padding: 0.55rem 1rem;
      border-radius: 1rem;
      border: 1px solid rgba(13,185,242,0.14);
      background: rgba(16,30,34,0.7);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
    "
  >
    <!-- Brand link -->
    <a
      href={wwwUrl}
      style="
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.82rem;
        font-weight: 700;
        color: rgba(148,163,184,0.85);
        text-decoration: none;
        transition: color 0.18s;
      "
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="rgba(13,185,242,0.8)">
        <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" />
      </svg>
      <span>StealThis.dev</span>
    </a>

    <!-- Center divider / title -->
    <div style="display:flex; align-items:center; gap:0.6rem;">
      <div
        style="
          width:1.6rem; height:1.6rem; border-radius:0.45rem;
          background:#0db9f2; display:grid; place-content:center;
          box-shadow: 0 0 10px rgba(13,185,242,0.35);
        "
      >
        <svg width="11" height="11" viewBox="0 0 24 24" fill="#0a1215">
          <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" />
        </svg>
      </div>
      <span
        style="
          font-size:0.88rem; font-weight:800; color:#f8fafc;
          letter-spacing:-0.01em;
        "
      >
        StyleForge
      </span>
    </div>

    <!-- Badge -->
    <div style="display:inline-flex; align-items:center; gap:0.5rem;">
      <span
        style="
          border-radius: 999px;
          border: 1px solid rgba(13,185,242,0.35);
          background: rgba(13,185,242,0.1);
          padding: 0.22rem 0.7rem;
          font-size: 0.65rem;
          font-weight: 800;
          letter-spacing: 0.1em;
          text-transform: uppercase;
          color: #0db9f2;
        "
      >
        MVP
      </span>
    </div>
  </header>

  <main class="w-full">
    <StyleForgeStudio client:only="react" />
  </main>
</body>
</html>
